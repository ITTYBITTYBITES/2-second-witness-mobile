[gd_scene load_steps=2 format=3 uid="uid://tutorial_screen"]

[ext_resource type="Script" path="res://src/ui/screens/TutorialScreen.gd" id="1_script"]

[node name="TutorialScreen" type="Control" groups=["app_screen"]]
layout_mode=3
anchors_preset=15
anchor_right=1.0
anchor_bottom=1.0
grow_horizontal=2
grow_vertical=2
script=ExtResource("1_script")

[node name="Background" type="ColorRect" parent="."]
layout_mode=1
anchors_preset=15
anchor_right=1.0
anchor_bottom=1.0
grow_horizontal=2
grow_vertical=2
color=Color(0.0588235, 0.0588235, 0.0705882, 1)
mouse_filter=2

[node name="Margin" type="MarginContainer" parent="."]
layout_mode=1
anchors_preset=15
anchor_right=1.0
anchor_bottom=1.0
grow_horizontal=2
grow_vertical=2
custom_constants/margin_left=24
custom_constants/margin_right=24
custom_constants/margin_top=24
custom_constants/margin_bottom=24

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode=2
custom_constants/separation=24
alignment=1

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode=2
text="Step 1: Observe"
horizontal_alignment=1
autowrap_mode=3

[node name="StepContainer" type="PanelContainer" parent="Margin/VBox"]
custom_minimum_size=Vector2(0, 160)
layout_mode=2

[node name="StepLabel" type="Label" parent="Margin/VBox/StepContainer"]
layout_mode=2
text="OBSERVE"
horizontal_alignment=1
vertical_alignment=1

[node name="Description" type="Label" parent="Margin/VBox"]
layout_mode=2
text="You have exactly two seconds to study the scene. Every detail matters."
horizontal_alignment=1
autowrap_mode=3

[node name="PageIndicator" type="HBoxContainer" parent="Margin/VBox"]
layout_mode=2
custom_constants/separation=12
alignment=1

[node name="Dot1" type="ColorRect" parent="Margin/VBox/PageIndicator"]
custom_minimum_size=Vector2(12, 12)
layout_mode=2
color=Color(0.415686, 0.239216, 1, 1)

[node name="Dot2" type="ColorRect" parent="Margin/VBox/PageIndicator"]
custom_minimum_size=Vector2(12, 12)
layout_mode=2
color=Color(0.180392, 0.180392, 0.227451, 1)

[node name="Dot3" type="ColorRect" parent="Margin/VBox/PageIndicator"]
custom_minimum_size=Vector2(12, 12)
layout_mode=2
color=Color(0.180392, 0.180392, 0.227451, 1)

[node name="Actions" type="VBoxContainer" parent="Margin/VBox"]
layout_mode=2
custom_constants/separation=8

[node name="NextButton" type="Button" parent="Margin/VBox/Actions"]
custom_minimum_size=Vector2(0, 56)
layout_mode=2
text="Next"

[node name="SkipButton" type="Button" parent="Margin/VBox/Actions"]
custom_minimum_size=Vector2(0, 48)
layout_mode=2
text="Skip Tutorial"
flat=true

[connection signal="pressed" from="Margin/VBox/Actions/NextButton" to="." method="_on_next_pressed"]
[connection signal="pressed" from="Margin/VBox/Actions/SkipButton" to="." method="_on_skip_pressed"]
