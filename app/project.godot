; Engine configuration file.
; Two Second Witness - Foundation Rebuild
; Godot 4.6 - Clean Architecture

config_version=5

[application]
config/name="2 Second Witness"
config/description="Short, replayable experiences focused on observation, memory, reaction, and quick decision-making."
run/main_scene="res://src/ui/shell/AppShell.tscn"
config/features=PackedStringArray("4.6", "Mobile")
boot_splash/image="res://assets/brand/app_icon_1024.png"
boot_splash/fullsize=false
boot_splash/bg_color=Color(0.055, 0.055, 0.08, 1)
config/icon="res://assets/brand/app_icon_1024.png"

[autoload]
EventBus="*res://src/core/events/EventBus.gd"
AppConfig="*res://src/systems/config/ConfigService.gd"
ConfigService="*res://src/systems/config/ConfigService.gd"
ErrorHandler="*res://src/core/app/ErrorHandler.gd"
AnalyticsService="*res://src/systems/analytics/AnalyticsService.gd"
SettingsService="*res://src/systems/settings/SettingsService.gd"
SaveService="*res://src/systems/save/SaveService.gd"
ProfileService="*res://src/systems/save/ProfileService.gd"
ThemeService="*res://src/systems/theme/ThemeService.gd"
AudioService="*res://src/systems/audio/AudioService.gd"
AccessibilityService="*res://src/systems/accessibility/AccessibilityService.gd"
ContentService="*res://src/systems/content/ContentService.gd"
ExperienceRegistry="*res://src/systems/content/ExperienceRegistry.gd"
NavigationService="*res://src/core/navigation/NavigationService.gd"
AppState="*res://src/core/app/AppState.gd"

[display]
window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[input]
tap={
"deadzone": 0.5,
"events": [Object(InputEventScreenTouch,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"index":0,"pressed":false,"x":0,"y":0) ]
}

[input_devices]
pointing/emulate_touch_from_mouse=true

[rendering]
renderer/rendering_method="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
environment/defaults/default_clear_color=Color(0.06, 0.06, 0.09, 1)

[dotnet]
project/assembly_name="TwoSecondWitness"
