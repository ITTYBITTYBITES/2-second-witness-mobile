; Engine configuration file.
; It's best edited using the editor UI and not directly.

config_version=5

[application]

config/name="2 Second Witness"
run/main_scene="res://MainShell.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[rendering]

textures/vram_compression/import_etc2_astc=true
shader_compiler/shader_cache/enabled=true
vulkan/rendering/shader_compilation_mode=2

[autoload]

AudioManager="*res://scripts/system/AudioManager.gd"
GoodwillManager="*res://scripts/system/GoodwillManager.gd"
NavigationEngine="*res://scripts/NavigationEngine.gd"

NavigationRouter="*res://scripts/NavigationRouter.gd"
ThemeManager="*res://scripts/ThemeManager.gd"
ContentRegistry="*res://scripts/content/ContentRegistry.gd"
ContentLoader="*res://scripts/content/ContentLoader.gd"
SystemHealthMonitor="*res://scripts/system/SystemHealthMonitor.gd"
ContentSnapshotManager="*res://scripts/system/deployment/ContentSnapshotManager.gd"
SessionTracker="*res://scripts/system/SessionTracker.gd"
GitHubSyncManager="*res://scripts/content/GitHubSyncManager.gd"
FidelityEnforcer="*res://scripts/system/enforcement/FidelityEnforcer.gd"
SamplingController="*res://scripts/system/SamplingController.gd"
PlayerProfile="*res://scripts/system/PlayerProfile.gd"
StoreManager="*res://scripts/system/StoreManager.gd"
AdManager="*res://scripts/system/AdManager.gd"
DiagnosticAutomator="*res://scripts/system/DiagnosticAutomator.gd"
IVC0_InstrumentConfig="*res://scripts/system/IVC0_InstrumentConfig.gd"
StructuredLogger="*res://scripts/system/StructuredLogger.gd"
LensMorphology="*res://scripts/system/LensMorphology.gd"

[display]
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]
pointing/emulate_touch_from_mouse=true
pointing/emulate_mouse_from_touch=true
