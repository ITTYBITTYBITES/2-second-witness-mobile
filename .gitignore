# Godot 4+ specific ignores
.godot/
*.translation

# Build outputs - keep export_presets.cfg tracked
app/build/
build/
*.apk
*.aab
*.keystore
*.pck
*.zip

# User local data
user/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.py[cod]
.venv/
.trailer-venv/

# Logs
*.log
app/logs/

# Godot import cache - keep production asset imports tracked for export continuity
*.import
!app/assets/**/*.import
!app/assets/**/

# Analytics local buffer
user_analytics.jsonl
analytics_buffer.jsonl
